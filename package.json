{
  "name": "igdb-sdk",
  "version": "0.1.0",
  "description": "Unofficial IGDB API v4 SDK for TypeScript",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "igdb",
    "twitch",
    "sdk",
    "api",
    "games",
    "videogames"
  ],
  "license": "MIT",
  "author": "Carlos Costa (https://github.com/carllosnc)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carllosnc/igdb-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/carllosnc/igdb-sdk/issues"
  },
  "homepage": "https://github.com/carllosnc/igdb-sdk#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
