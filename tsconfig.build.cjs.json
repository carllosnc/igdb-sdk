{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/cjs",
    "rootDir": "src",
    "sourceMap": true,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
